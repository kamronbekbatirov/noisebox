# NoiseBox relay environment.
# Copy to `.env` (gitignored) on your VPS and fill in the values.

# Telegram bot token from @BotFather. SAME token as device firmware's
# NOISE_BOT_TOKEN. Treat as a shared secret.
BOT_TOKEN=PASTE_YOUR_TOKEN_FROM_BOTFATHER

# Listen address for the internal HTTP API. Caddy proxies to this.
HTTP_HOST=127.0.0.1
HTTP_PORT=8081

# Persistent state file (rooms, peers, device_token map). Survives restart.
STATE_FILE=/opt/cardputer-relay/state.json

# Enable the /admin/issue_token test endpoint? Set to 1 ONLY during
# development with peer_ghost.py. NEVER enable in production: this
# endpoint mints device tokens for arbitrary user_chat_id values when
# called with the bot_token.
# NOISE_TEST_ADMIN=0
