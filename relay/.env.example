# NoiseBox relay environment.
# Copy to `.env` (gitignored) and fill in.
#
# For Docker Compose deploy, BOT_TOKEN and DOMAIN are required;
# HTTP_HOST/PORT have sensible defaults for the in-container relay.

# Telegram bot token from @BotFather. Must match the same token entered
# on each user's Cardputer under "Relay setup" on first boot.
BOT_TOKEN=PASTE_YOUR_TOKEN_FROM_BOTFATHER

# Public hostname of this relay. Used by Caddy (Docker deploy) to obtain
# a Let's Encrypt certificate. DNS must point at this server.
DOMAIN=relay.your-domain.example.com

# In-container listen address. Caddy proxies to this; you typically
# don't change these.
HTTP_HOST=0.0.0.0
HTTP_PORT=8081

# Persistent state file (rooms, peers, device_token map).
STATE_FILE=/data/state.json

# DO NOT enable in production. Enables the /_admin/issue_token endpoint
# used by relay/peer_ghost.py during testing. Anyone with BOT_TOKEN can
# mint a device_token for any user_chat_id when this is on.
# NOISE_TEST_ADMIN=0
