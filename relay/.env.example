# NoiseBox relay environment.
# Copy to `.env` (gitignored) and fill in.
#
# For Docker Compose deploy, BOT_TOKEN, RELAY_ID, and DOMAIN are
# required; HTTP_HOST/PORT have sensible defaults for the in-container
# relay.

# Telegram bot token from @BotFather. SECRET — relay-only. Never share
# with users or put in firmware. Compromise = anyone can read/send via
# your bot through Telegram Bot API.
BOT_TOKEN=PASTE_YOUR_TOKEN_FROM_BOTFATHER

# Public-ish identifier of THIS relay. Users enter this (alongside the
# relay host) on first boot of their Cardputer; it gates the public
# /bind_poll endpoint. NOT a Telegram secret — safe to share with the
# friends you want to chat with. Pick anything memorable, or generate
# with: nb_$(openssl rand -hex 8)
RELAY_ID=nb_CHANGEME

# Public hostname of this relay. Used by Caddy (Docker deploy) to obtain
# a Let's Encrypt certificate. DNS must point at this server.
DOMAIN=relay.your-domain.example.com

# In-container listen address. Caddy proxies to this; you typically
# don't change these.
HTTP_HOST=0.0.0.0
HTTP_PORT=8081

# Persistent state file (rooms, peers, device_token map).
STATE_FILE=/data/state.json

# DO NOT enable in production. Enables the /_admin/issue_token endpoint
# used by relay/peer_ghost.py during testing. Anyone with BOT_TOKEN can
# mint a device_token for any user_chat_id when this is on.
# NOISE_TEST_ADMIN=0
