#pragma once
// NoiseBox firmware build-time configuration.
//
// Copy this file to `config.h` (in .gitignore, never commit) and fill in
// the placeholders before running `idf.py build`.

// The Telegram bot token issued by @BotFather. Same token is configured
// on the VPS relay's .env (BOT_TOKEN=...). Treat as a SHARED SECRET --
// anyone who has it can read business-mode-routed traffic for users who
// connected the bot. On the device this token is used ONLY for the
// unauthenticated /bind_poll endpoint; everything else uses a per-device
// bearer token issued by the relay during /pair.
#define NOISE_BOT_TOKEN   "0000000000:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

// Public hostname of the relay (the same domain Caddy is fronting on 443).
#define NOISE_RELAY_HOST  "your-domain.example.com"

// Optional default Wi-Fi for first-boot convenience. Leave blank to always
// show the on-device Wi-Fi picker on first boot (recommended).
#define NOISE_DEFAULT_SSID  ""
#define NOISE_DEFAULT_PASS  ""
