#pragma once
// NoiseBox firmware build-time configuration.
//
// Copy this file to `config.h` (in .gitignore, never commit) and fill in
// the placeholders before running `idf.py build`. You can leave the
// placeholders in and enter both values on the device's first-boot
// "Relay setup" screen instead.

// Public-ish identifier of the relay you're using. Matches RELAY_ID in
// the relay operator's .env. NOT a Telegram secret — your friend who
// runs the relay can hand this to you alongside their domain without
// exposing their bot token.
#define NOISE_RELAY_ID   "nb_XXXXXXXXXXXXXXXX"

// Public hostname of the relay (the same domain Caddy is fronting on 443).
#define NOISE_RELAY_HOST  "your-domain.example.com"

// Optional default Wi-Fi for first-boot convenience. Leave blank to always
// show the on-device Wi-Fi picker on first boot (recommended).
#define NOISE_DEFAULT_SSID  ""
#define NOISE_DEFAULT_PASS  ""
